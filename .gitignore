# Build output
bin/
obj/

# IDE
.vs/
.vscode/
.idea/
*.user

# Environment
.env
.env.local

# Logs / runtime
*.log
*.pid

# OS
.DS_Store
Thumbs.db

# Test artifacts
TestResults/
coverage/

# Docker volumes (in case anyone bind-mounts)
.data/

# Python (eval harness)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/

# Eval runner output — `baseline.json` is the gate's reference and IS committed;
# `latest.json` is regenerated on every run and should not be.
evals/results/latest.json

# P3 local blob store — uploaded PDFs persist here in dev; never committed.
# Default root is apps/api/Api/blob-store via Program.cs; ops can override
# via BLOB_STORE_ROOT.
apps/api/Api/blob-store/
